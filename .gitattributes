# Auto detect text files and normalize line endings to LF
* text=auto

# Go files
*.go text eol=lf

# SQL files
*.sql text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Markdown
*.md text eol=lf

# YAML files
*.yml text eol=lf
*.yaml text eol=lf

# JSON
*.json text eol=lf

# Makefiles (must use tabs)
Makefile text eol=lf

# Docker files
Dockerfile text eol=lf
*.dockerfile text eol=lf
compose.yaml text eol=lf
docker-compose.yml text eol=lf
docker-compose.yaml text eol=lf

# Config files
*.conf text eol=lf
*.config text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.db binary
*.sqlite binary
